# OpenRouter API Key (required for LLM + embeddings)
OPEN_ROUTER_KEY=your_openrouter_key_here

# Google OAuth (optional — falls back to mock)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# LinkedIn OAuth (optional — falls back to mock)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# LinkedIn Scraper Credentials (optional — for Selenium-based scraping)
LinkedinLogin=your_linkedin_email@example.com
LinkedinPassword=your_linkedin_password

# Encryption key for server-side credential storage (Fernet)

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Auto-generated on first run if missing or set to placeholder.
# To generate manually: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

ENCRYPTION_KEY=your_fernet_key_here

# App URLs (set to your Render service URL in production)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# SMTP Configuration for Email Notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=bijumathewai@gmail.com
SMTP_PASSWORD=xxxxxxxxxxxxxxxx
SMTP_SENDER=bijumathewai@gmail.com
